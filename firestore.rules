rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && (!('role' in incoming()) || incoming().role == 'user');
      allow update: if (isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'lastLoginAt'])
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt) || isAdmin();
      allow delete: if isAdmin();

      function isValidUser(data) {
        return data.uid == request.auth.uid
          && data.email is string && data.email.size() < 256
          && (('membershipType' in data) == false || data.membershipType in ['free', 'standard', 'pro'])
          && (data.displayName == null || (data.displayName is string && data.displayName.size() < 100))
          && data.createdAt == (resource == null ? request.time : existing().createdAt);
      }
    }

    // Chat History Rules
    match /chats/{chatId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid || isAdmin();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidChat(incoming());
      allow update: if (isSignedIn() && existing().userId == request.auth.uid && isValidChat(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'title', 'updatedAt', 'mode'])
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt) || isAdmin();
      allow delete: if isSignedIn() && existing().userId == request.auth.uid || isAdmin();

      function isValidChat(data) {
        return data.userId == request.auth.uid
          && data.messages is list && data.messages.size() <= 1000
          && (data.title == null || (data.title is string && data.title.size() < 200))
          && data.createdAt == (resource == null ? request.time : existing().createdAt);
      }
    }

    // File Asset Rules
    match /files/{fileId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid || isAdmin();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidFile(incoming());
      allow update: if isAdmin(); // Files metadata are usually immutable
      allow delete: if isSignedIn() && existing().userId == request.auth.uid || isAdmin();

      function isValidFile(data) {
        return data.userId == request.auth.uid
          && data.name is string && data.name.size() < 255
          && data.url is string && data.url.size() < 1024
          && data.type is string && data.type.size() < 50
          && data.createdAt == request.time;
      }
    }

    // Artifact Rules
    match /artifacts/{artifactId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid || isAdmin();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidArtifact(incoming());
      allow update: if false || isAdmin(); // Artifacts are usually immutable
      allow delete: if isSignedIn() && existing().userId == request.auth.uid || isAdmin();

      function isValidArtifact(data) {
        return data.userId == request.auth.uid
          && data.type in ['code', 'image', 'markdown']
          && data.title is string && data.title.size() < 255
          && data.content is string && data.content.size() < 1048576 // 1MB limit for safety
          && (data.language == null || (data.language is string && data.language.size() < 50))
          && (data.chatId == null || (data.chatId is string && data.chatId.size() <= 128))
          && data.createdAt == request.time;
      }
    }
  }
}
